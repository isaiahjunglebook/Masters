# Copy this file to .env.local for local development.
# On Vercel, set these in Project Settings → Environment Variables instead.

# Shared password that gates the page (pick anything you'll remember)
PAGE_PASSWORD=pick-a-password

# --- Optional: only needed when YouTube bot-blocks your host's IPs ---
# (Cloud hosts like Vercel get "Sign in to confirm you're not a bot".
#  Running locally on a home connection usually needs neither.)

# Option A: your logged-in youtube.com Cookie header value.
# Free, but cookies expire every few weeks/months and automated use
# carries a small risk of Google flagging the account.
# YOUTUBE_COOKIE=VISITOR_INFO1_LIVE=...; SID=...; ...

# Option B: a residential proxy URL (e.g. Webshare/Decodo rotating
# residential). Costs a few $/month, no account risk.
# PROXY_URL=http://username:password@host:port
